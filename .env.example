# ============================================================
# TikTok 外贸行业对标视频发现系统 — 环境变量配置
# 复制为 .env 后修改即可生效
# ============================================================

# ── LLM API Key (至少设置一个) ──
# DeepSeek (推荐, 约 1/10 的 OpenAI 成本)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# OpenAI (备选)
OPENAI_API_KEY=sk-your-openai-key-here

# ── Flask 安全配置 ──
# 生产环境务必修改为随机字符串
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tiktok-analyzer-change-me-in-production

# ── Flask 运行模式 ──
# development=开启 debug 模式 + 详细错误页面
# production =关闭 debug, 仅 INFO 日志
FLASK_ENV=development

# ── 日志级别 ──
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
